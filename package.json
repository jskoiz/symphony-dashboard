{
  "name": "symphony-dashboard",
  "version": "0.1.0",
  "description": "A local rollup dashboard for multiple Symphony observability servers.",
  "type": "module",
  "bin": {
    "symphony-dashboard": "./src/server.mjs",
    "symphony-dashboard-status": "./src/status.mjs"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "demo": "npm run demo:watch",
    "demo:watch": "SYMPHONY_DASHBOARD_CONFIG=config/projects.sample.json node --watch --watch-path=src --watch-path=config src/server.mjs",
    "demo:once": "SYMPHONY_DASHBOARD_CONFIG=config/projects.sample.json node src/server.mjs",
    "status": "node src/status.mjs",
    "check": "node --check src/server.mjs && node --check src/status.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "symphony",
    "codex",
    "dashboard",
    "linear"
  ],
  "license": "MIT"
}
